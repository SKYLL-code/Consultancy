# Copy this file to .env and set your backend keys and endpoints.
PAYCHANGU_SECRET_KEY=sk_test_your_secret_key_here
PORT=3000

# Optional: Configure an AI provider for the Customize with AI feature.
# Set AI_PROVIDER=gemini to use Gemini cloud, or AI_PROVIDER=local to use a local runtime.
AI_PROVIDER=gemini
# GEMINI_API_TYPE options: free (generativelanguage.googleapis.com - free tier), vertex (Vertex AI Platform - requires billing)
GEMINI_API_TYPE=free
GEMINI_API_KEY=your_gemini_api_key_here
GEMINI_MODEL=gemini-1.5-mini

# Local AI fallback (set AI_PROVIDER=local to use this instead)
LOCAL_AI_URL=http://127.0.0.1:8080
LOCAL_AI_MODEL=Salesforce/codegen-350M-multi
LOCAL_AI_API_KEY=
